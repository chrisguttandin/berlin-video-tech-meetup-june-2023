{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "cli": {
        "analytics": false
    },
    "newProjectRoot": "projects",
    "projects": {
        "berlin-video-tech-meetup-june-2023": {
            "architect": {
                "build": {
                    "builder": "@angular-builders/custom-esbuild:application",
                    "configurations": {
                        "development": {
                            "extractLicenses": false,
                            "namedChunks": true,
                            "optimization": false,
                            "sourceMap": true
                        },
                        "production": {
                            "budgets": [
                                {
                                    "maximumError": "1mb",
                                    "maximumWarning": "500kb",
                                    "type": "initial"
                                },
                                {
                                    "maximumError": "4kb",
                                    "maximumWarning": "2kb",
                                    "type": "anyComponentStyle"
                                }
                            ],
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.prod.ts"
                                }
                            ],
                            "indexHtmlTransformer": "config/esbuild/transform.mjs",
                            "outputHashing": "all",
                            "sourceMap": {
                                "hidden": true,
                                "scripts": true,
                                "styles": false
                            }
                        }
                    },
                    "defaultConfiguration": "production",
                    "options": {
                        "assets": ["src/assets"],
                        "browser": "src/main.ts",
                        "i18nMissingTranslation": "error",
                        "index": "src/index.html",
                        "outputPath": "build/berlin-video-tech-meetup-june-2023",
                        "polyfills": ["zone.js"],
                        "prerender": true,
                        "scripts": ["hammerjs/hammer.js"],
                        "server": "src/main.server.ts",
                        "serviceWorker": "src/ngsw-config.json",
                        "ssr": {
                            "entry": "src/server.ts"
                        },
                        "styles": ["prismjs/themes/prism-okaidia.css", "src/styles/styles.scss"],
                        "tsConfig": "src/tsconfig.json"
                    }
                },
                "extract-i18n": {
                    "builder": "@angular/build:extract-i18n",
                    "options": {
                        "buildTarget": "berlin-video-tech-meetup-june-2023:build"
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "configurations": {
                        "test": {
                            "eslintConfig": "config/eslint/test.eslint.config.mjs",
                            "lintFilePatterns": ["test/**/*.html", "test/**/*.ts"]
                        }
                    },
                    "options": {
                        "eslintConfig": "config/eslint/src.eslint.config.mjs",
                        "lintFilePatterns": ["src/**/*.html", "src/**/*.ts"]
                    }
                },
                "serve": {
                    "builder": "@angular-builders/custom-esbuild:dev-server",
                    "configurations": {
                        "development": {
                            "buildTarget": "berlin-video-tech-meetup-june-2023:build:development"
                        },
                        "production": {
                            "buildTarget": "berlin-video-tech-meetup-june-2023:build:production"
                        }
                    },
                    "defaultConfiguration": "development",
                    "options": {
                        "port": 6677
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "browsers": ["chrome"],
                        "headless": true,
                        "include": ["../test/unit/**/*.ts"],
                        "tsConfig": "test/unit/tsconfig.json"
                    }
                }
            },
            "prefix": "vtm",
            "projectType": "application",
            "root": "",
            "schematics": {},
            "sourceRoot": "src"
        }
    },
    "schematics": {
        "@schematics/angular:application": {
            "strict": true
        },
        "@schematics/angular:class": {
            "skipTests": true
        },
        "@schematics/angular:component": {
            "changeDetection": "OnPush",
            "inlineStyle": false,
            "inlineTemplate": false,
            "prefix": "vtm",
            "skipTests": true,
            "style": "scss",
            "type": "component"
        },
        "@schematics/angular:directive": {
            "prefix": "vtm",
            "skipTests": true,
            "type": "directive"
        },
        "@schematics/angular:guard": {
            "typeSeparator": "."
        },
        "@schematics/angular:interceptor": {
            "typeSeparator": "."
        },
        "@schematics/angular:interface": {
            "prefix": "I"
        },
        "@schematics/angular:module": {
            "skipTests": true,
            "typeSeparator": "."
        },
        "@schematics/angular:pipe": {
            "skipTests": true,
            "typeSeparator": "."
        },
        "@schematics/angular:resolver": {
            "typeSeparator": "."
        },
        "@schematics/angular:service": {
            "skipTests": true,
            "type": "service"
        }
    },
    "version": 1
}
